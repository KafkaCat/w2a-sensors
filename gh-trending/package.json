{
  "name": "@kafkacat/w2a-gh-trending",
  "version": "0.1.0",
  "description": "W2A sensor — periodic digest of trending repositories on GitHub (daily or weekly).",
  "keywords": [
    "world2agent",
    "w2a",
    "w2a-sensor",
    "sensor",
    "agent",
    "github",
    "trending"
  ],
  "license": "MIT",
  "author": "KafkaCat",
  "homepage": "https://github.com/KafkaCat/w2a-sensors/tree/main/gh-trending",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KafkaCat/w2a-sensors.git",
    "directory": "gh-trending"
  },
  "bugs": {
    "url": "https://github.com/KafkaCat/w2a-sensors/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "w2a-gh-trending": "dist/bin.js"
  },
  "scripts": {
    "start": "node dist/bin.js",
    "build": "tsc --build",
    "clean": "rm -rf dist *.tsbuildinfo",
    "smoke": "node dist/smoke.js",
    "test": "node --test dist/test/transform.test.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@world2agent/sdk": "^0.1.0-alpha.1",
    "cheerio": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/test/**",
    "!dist/smoke.*",
    "SETUP.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "w2a": {
    "type": "sensor",
    "source_type": "github",
    "signals": [
      "repo.trending.refreshed"
    ],
    "setup": "./SETUP.md"
  }
}
